{
  "statePath": "cluster/coordinator.sqlite",
  "authorityPath": "cluster/coordinator.identity.json",
  "peerEndpoints": [
    "https://peer-1.example.net:9443",
    "https://peer-2.example.net:9443",
    "https://peer-3.example.net:9443",
    "https://peer-4.example.net:9443",
    "https://peer-5.example.net:9443"
